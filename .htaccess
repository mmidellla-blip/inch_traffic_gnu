# Hostinger / LiteSpeed: mod_expires·mod_headers 조합이 500을 유발하는 경우가 많아 최소 설정만 사용합니다.
# 캐시·SEO ErrorDocument·전체 리라이트 복원 시 → .htaccess.full 내용을 이 파일로 복사하세요.

DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Hostinger 임시 도메인(*.hostingersite.com): 아래 HTTPS·www 규칙을 적용하지 않음
RewriteCond %{HTTP_HOST} \.hostingersite\.com$ [NC]
RewriteRule ^ - [L]

RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost(:\d+)?$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:\d+)?$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

RewriteCond %{HTTP_HOST} ^www\.trafficdrinking-law-dongju\.com$ [NC]
RewriteRule ^(.*)$ https://trafficdrinking-law-dongju.com/$1 [R=301,L]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

</IfModule>
